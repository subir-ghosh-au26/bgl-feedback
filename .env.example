# Admin credentials (CHANGE THESE in production!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_strong_password

# Server
PORT=3000
NODE_ENV=production

# Session secret (generate a strong random string!)
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_secure_random_string

# MongoDB Atlas (Free Tier)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/bgl-feedback?retryWrites=true&w=majority

# The base URL where the app is hosted (used for QR code generation)
BASE_URL=https://your-domain.com
